# Copy to ".env" and fill values. Used by Django and by docker-compose.

# --- Required in production ---
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,yourdomain.com

# Frontend origins (comma-separated). Add your deployed UI URL.
DJANGO_CORS_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173,http://localhost:8080

# Optional: set true only if you intentionally allow any browser origin (not recommended in prod)
# DJANGO_CORS_ALLOW_ALL=false

# SQLite path (optional). Default: db.sqlite3 next to manage.py.
# In Docker Compose we set: /data/db.sqlite3
# DJANGO_SQLITE_PATH=

# --- Email (bulk sender) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_USE_TLS=true

# --- Optional integrations ---
# SERPAPI_KEY=   # Google SERP results for keyword search (otherwise DuckDuckGo / mock URLs)
